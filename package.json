{
  "name": "superior-series",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@9.1.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint . && eslint \"src/**/*.svelte\"",
    "lint:fix": "oxlint . --fix && eslint \"src/**/*.svelte\" --fix",
    "lint:strict": "oxlint . --deny-warnings && eslint \"src/**/*.svelte\" --max-warnings 0",
    "typecheck": "astro check",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/svelte": "^8.0.4",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "astro": "^6.1.1",
    "peerjs": "^1.5.5",
    "qrcode": "^1.5.4",
    "svelte": "^5.55.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.2"
  }
}
