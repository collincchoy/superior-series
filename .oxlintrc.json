{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "coverage",
    ".astro",
    "**/*.astro",
    "**/*.svelte"
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  }
}
