---
import CatanApp from '../components/catan/CatanApp.svelte';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta name="theme-color" content="#8b6914" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href="/superior-series/catan-manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/superior-series/catan-icons/icon-192.svg" />
    <title>Catan: Cities &amp; Knights</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        font-family: system-ui, sans-serif;
        background: #1a3a1a;
        color: #f0e8d0;
        overflow: hidden;
      }

      #app {
        height: 100%;
        display: flex;
        flex-direction: column;
      }

      /* ── Lobby ──────────────────────────────────────────────────── */

      .catan-app {
        height: 100%;
        overflow: auto;
      }

      .lobby {
        max-width: 480px;
        margin: 0 auto;
        padding: 1.5rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .lobby h1 {
        font-size: 1.6rem;
        color: #f5c842;
        text-align: center;
      }

      .lobby h2 {
        font-size: 1rem;
        color: #c8b47a;
        margin-bottom: 0.5rem;
      }

      .lobby-section {
        background: rgba(255,255,255,0.05);
        border-radius: 8px;
        padding: 1rem;
      }

      .slot-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
      }

      .slot-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .slot-color {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .slot-name {
        flex: 1;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        padding: 0.4rem 0.6rem;
        color: #f0e8d0;
        font-size: 0.9rem;
      }

      .slot-type {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        padding: 0.4rem 0.4rem;
        color: #f0e8d0;
        font-size: 0.85rem;
      }

      .btn-remove {
        background: none;
        border: none;
        color: #e74c3c;
        cursor: pointer;
        font-size: 1rem;
        padding: 0.2rem;
      }

      .join-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .join-row input {
        flex: 1;
        min-width: 100px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        padding: 0.5rem 0.6rem;
        color: #f0e8d0;
        font-size: 0.9rem;
      }

      .btn-primary {
        background: #8b6914;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 0.6rem 1.2rem;
        font-size: 0.95rem;
        cursor: pointer;
        font-weight: 600;
      }
      .btn-primary:hover { background: #a07a1a; }
      .btn-primary:disabled { opacity: 0.4; cursor: default; }

      .btn-secondary {
        background: rgba(255,255,255,0.1);
        color: #f0e8d0;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 6px;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        cursor: pointer;
      }
      .btn-secondary:hover { background: rgba(255,255,255,0.15); }

      .btn-large { width: 100%; padding: 0.9rem; font-size: 1.1rem; }

      .lobby-status {
        text-align: center;
        font-size: 0.9rem;
        color: #c8b47a;
        min-height: 1.2em;
      }
      .lobby-status.error { color: #e74c3c; }

      /* ── Game Layout ────────────────────────────────────────────── */

      .game-layout {
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      .room-code-banner {
        background: #2c5f2e;
        text-align: center;
        padding: 0.3rem 1rem;
        font-size: 0.8rem;
        color: #c8f5c8;
        flex-shrink: 0;
      }

      .board-area {
        flex: 1;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #1a3a6e;
        overflow: hidden;
      }

      .board-svg {
        width: 100%;
        height: 100%;
        max-height: 100%;
        max-width: 100%;
      }

      .side-panel {
        flex-shrink: 0;
        max-height: 45vh;
        overflow-y: auto;
        background: #1a2a1a;
        border-top: 2px solid #2c5f2e;
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      @media (min-width: 700px) {
        .game-layout {
          flex-direction: row;
        }
        .board-area {
          flex: 1;
        }
        .side-panel {
          width: 260px;
          max-height: 100vh;
          border-top: none;
          border-left: 2px solid #2c5f2e;
          overflow-y: auto;
        }
      }

      /* ── Phase Banner ───────────────────────────────────────────── */

      .phase-banner {
        background: #2c3e2c;
        padding: 0.5rem 0.8rem;
        font-size: 0.85rem;
        color: #c8b47a;
        border-bottom: 1px solid #2c5f2e;
      }
      .phase-banner.my-turn {
        background: #3a5e1e;
        color: #f5c842;
        font-weight: 600;
      }

      /* ── Players Panel ──────────────────────────────────────────── */

      .players-panel {
        border-bottom: 1px solid #2c5f2e;
        padding: 0.4rem 0;
      }

      .player-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.3rem 0.8rem;
        font-size: 0.8rem;
        opacity: 0.6;
      }
      .player-row.active { opacity: 1; background: rgba(255,255,255,0.05); }
      .player-name { flex: 1; font-weight: 500; }
      .player-vp { color: #f5c842; font-weight: 700; }
      .player-cards { color: #a0b0a0; }

      /* ── Hand Panel ─────────────────────────────────────────────── */

      .hand-panel {
        padding: 0.5rem 0.8rem;
        border-bottom: 1px solid #2c5f2e;
        font-size: 0.8rem;
      }
      .hand-title { font-size: 0.7rem; text-transform: uppercase; color: #c8b47a; margin-bottom: 0.3rem; }
      .hand-cards { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.3rem; }
      .card {
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
        padding: 0.15rem 0.4rem;
        font-size: 0.75rem;
      }
      .progress-cards { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.3rem; }
      .prog-card {
        background: rgba(100,60,160,0.4);
        border: 1px solid rgba(180,120,255,0.3);
        border-radius: 4px;
        padding: 0.15rem 0.4rem;
        font-size: 0.7rem;
      }
      .vp-card { background: rgba(180,140,0,0.4); border-color: #f5c842; }
      .improvements { color: #a0b0a0; font-size: 0.75rem; }

      /* ── Action Panel ───────────────────────────────────────────── */

      .action-panel {
        padding: 0.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .action-btn {
        background: rgba(255,255,255,0.1);
        color: #f0e8d0;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 5px;
        padding: 0.4rem 0.7rem;
        font-size: 0.8rem;
        cursor: pointer;
      }
      .action-btn:hover:not(.disabled) { background: rgba(255,255,255,0.18); }
      .action-btn.active {
        background: #3a5e1e;
        border-color: #6dbf6d;
        color: #f5c842;
      }
      .action-btn.disabled {
        opacity: 0.3;
        cursor: default;
      }

      .action-instruction {
        padding: 0.5rem;
        font-size: 0.8rem;
        color: #f5c842;
        line-height: 1.4;
      }

      /* ── Log Panel ──────────────────────────────────────────────── */

      .log-panel {
        padding: 0.4rem 0.8rem;
        font-size: 0.7rem;
        color: #a0b0a0;
        max-height: 6rem;
        overflow-y: auto;
        flex: 1;
      }
      .log-line { padding: 0.1rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }

      /* ── Modal ──────────────────────────────────────────────────── */

      .modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
      }
      .modal.hidden { display: none; }

      .modal-box {
        background: #1e2e1e;
        border: 2px solid #2c5f2e;
        border-radius: 10px;
        padding: 1.2rem;
        max-width: 360px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
      }
      .modal-box h3 { margin-bottom: 1rem; color: #f5c842; }

      .discard-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 0.8rem;
      }
      .discard-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.9rem;
      }
      .counter {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .cnt-btn {
        background: rgba(255,255,255,0.1);
        color: #f0e8d0;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        width: 28px;
        height: 28px;
        cursor: pointer;
        font-size: 1rem;
      }

      .trade-section { margin-bottom: 0.8rem; }
      .trade-section label { font-size: 0.8rem; color: #c8b47a; margin-bottom: 0.3rem; display: block; }
      .trade-options { display: flex; flex-wrap: wrap; gap: 0.3rem; }
      .trade-card {
        background: rgba(255,255,255,0.08);
        color: #f0e8d0;
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 5px;
        padding: 0.35rem 0.6rem;
        font-size: 0.8rem;
        cursor: pointer;
      }
      .trade-card.selected { background: #3a5e1e; border-color: #6dbf6d; }
      .trade-actions { display: flex; gap: 0.5rem; margin-top: 0.8rem; }

      /* ── Toast ──────────────────────────────────────────────────── */

      .toast {
        position: fixed;
        bottom: 1rem;
        left: 50%;
        transform: translateX(-50%);
        background: #2c5f2e;
        color: #f0e8d0;
        padding: 0.6rem 1.2rem;
        border-radius: 20px;
        font-size: 0.9rem;
        z-index: 200;
        pointer-events: none;
      }
      .toast.error { background: #7a1e1e; }
      .toast.hidden { display: none; }

      /* ── Waiting Room ───────────────────────────────────────────── */

      .room-code-display {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.4rem;
      }

      .room-code-value {
        font-family: monospace;
        font-size: 1.3rem;
        font-weight: 700;
        color: #f5c842;
        letter-spacing: 0.05em;
        background: rgba(255,255,255,0.08);
        padding: 0.3rem 0.7rem;
        border-radius: 6px;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .join-hint {
        font-size: 0.8rem;
        color: #a0b0a0;
      }

      .waiting-player-list {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-bottom: 0.5rem;
      }

      .waiting-player-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.3rem 0;
      }

      .waiting-player-name {
        flex: 1;
        font-size: 0.9rem;
      }

      /* ── Board SVG highlight ring ───────────────────────────────── */

      .valid-vertex { cursor: pointer; }
      .valid-edge   { cursor: pointer; }
      .valid-hex    { cursor: pointer; }

      @keyframes pulse-ring {
        0%   { opacity: 0.6; r: 10; }
        50%  { opacity: 1;   r: 13; }
        100% { opacity: 0.6; r: 10; }
      }
      .valid-vertex circle { animation: pulse-ring 1.2s ease-in-out infinite; }
    </style>
  </head>
  <body>
    <div id="app">
      <CatanApp client:only="svelte" />
    </div>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/superior-series/catan-sw.js').catch(() => {});
      }
    </script>
  </body>
</html>
